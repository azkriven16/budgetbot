enum InvestmentAction {
  BUY
  SELL
}

model Investment {
  id            String           @id @default(cuid())
  userId        String
  ticker        String
  companyName   String?
  action        InvestmentAction
  shares        Decimal
  pricePerShare Decimal
  date          DateTime
  createdAt     DateTime         @default(now())

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
